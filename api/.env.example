NODE_ENV=development
PORT=4000

# Banco de dados
DATABASE_URL=mysql://franchise_user:franchise_password@localhost:3306/franchise_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=300

# Autenticacao
JWT_SECRET=change_me_super_secret_key
JWT_EXPIRES_IN=1h

# Email/SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Sistema de Franquias <your_email@gmail.com>"

# Upload/arquivos
UPLOAD_PATH=./uploads
BASE_URL=http://localhost:4000
API_URL=http://localhost:4000

# Integracao LLM/Scraping
GROQ_API_KEY=

# ou localmente com ollama
LLM_SERVICE=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
PUBLIC_ENVIRONMENT=development

# Testes de scraping (opcional)
RUN_SCRAPING_INTEGRATION_TESTS=false
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=
